# ===================================
# RNV Manager - Environment Variables
# ===================================
# Copia este archivo a .env y completa tus valores

# ── Base de Datos ─────────────────────────────────────────────────────────────
DB_USER=rnvadmin
DB_PASSWORD=rnv_secure_password_2025
DB_NAME=rnv_manager

# ── Go API ────────────────────────────────────────────────────────────────────
# Clave secreta para JWT (mínimo 32 caracteres, cambia en producción)
JWT_SECRET=rnv-super-secret-jwt-key-change-in-production-2025

# URL pública de la app
APP_URL=https://rnv.renace.tech

# ── Auth (legacy - para compatibilidad) ──────────────────────────────────────
# Si se define, se puede usar como contraseña maestra de admin
MASTER_PASSWORD=

# ── Hostinger API ─────────────────────────────────────────────────────────────
# Obtén tu token en: https://developers.hostinger.com
HOSTINGER_API_TOKEN=

# ── Odoo Integration ─────────────────────────────────────────────────────────
ODOO_URL=
ODOO_DB=
ODOO_USERNAME=
ODOO_API_KEY=

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ── GIN Mode (debug | release) ───────────────────────────────────────────────
GIN_MODE=release
